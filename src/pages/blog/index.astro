---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog')).sort(
  (a, b) => a.data.title.localeCompare(b.data.title, 'es'),
);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`Lista de Nombres · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <div class="page-hero">
      <h1>📚 Lista de Nombres</h1>
      <p id="counter">{posts.length} nombres con historia, origen y variantes</p>
      <div class="search-wrapper">
        <input
          type="search"
          id="search-input"
          placeholder="Buscar un nombre..."
          autocomplete="off"
          aria-label="Buscar nombre"
        />
      </div>
    </div>
    <main>
      <ul id="names-list">
        {posts.map((post) => (
          <li data-name={post.data.title.toLowerCase()}>
            <a href={`${base}/blog/${post.id}/`}>
              <div class="name-initial">{post.data.title.charAt(0)}</div>
              <div class="post-info">
                <h4 class="title">{post.data.title}</h4>
                <p class="desc">{post.data.description}</p>
                <p class="date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>
      <p id="no-results" style="display:none; text-align:center; color:#437c90; padding: 2em 0;">
        No se encontraron nombres que coincidan con tu búsqueda.
      </p>
    </main>
    <Footer />
  </body>
</html>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement;
  const list = document.getElementById('names-list')!;
  const counter = document.getElementById('counter')!;
  const noResults = document.getElementById('no-results')!;
  const items = list.querySelectorAll('li[data-name]') as NodeListOf<HTMLLIElement>;
  const total = items.length;

  input.addEventListener('input', () => {
    const query = input.value.toLowerCase().trim();
    let visible = 0;
    items.forEach(item => {
      const name = item.dataset.name || '';
      const match = name.includes(query);
      item.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    counter.textContent = query
      ? `${visible} nombre${visible !== 1 ? 's' : ''} encontrado${visible !== 1 ? 's' : ''}`
      : `${total} nombres con historia, origen y variantes`;
    noResults.style.display = visible === 0 ? '' : 'none';
    list.style.display = visible === 0 ? 'none' : '';
  });
</script>

<style>
  .page-hero {
    background: linear-gradient(135deg, #255957, #437c90);
    padding: 3em 2em;
    text-align: center;
    color: #eeebd3;
  }
  .page-hero h1 {
    color: #f7c548;
    margin: 0 0 0.3em;
    font-size: 2.4em;
  }
  .page-hero p {
    margin: 0 0 1.2em;
    opacity: 0.85;
    font-size: 1em;
  }
  .search-wrapper {
    max-width: 420px;
    margin: 0 auto;
  }
  #search-input {
    width: 100%;
    box-sizing: border-box;
    padding: 0.7em 1.2em;
    border-radius: 50px;
    border: none;
    font-size: 1em;
    font-family: inherit;
    background: rgba(238, 235, 211, 0.95);
    color: #255957;
    outline: none;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    transition: box-shadow 0.2s;
  }
  #search-input:focus {
    box-shadow: 0 4px 20px rgba(247, 197, 72, 0.5);
  }
  main {
    width: 100%;
    max-width: 960px;
    box-sizing: border-box;
    margin: 0 auto;
    padding: 3em 1em;
  }
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 1.5em;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  ul li a {
    display: flex;
    align-items: flex-start;
    gap: 1em;
    background: #fff;
    border-radius: 14px;
    padding: 1.4em;
    text-decoration: none;
    border: 1px solid rgba(67,124,144,0.15);
    box-shadow: 0 2px 10px rgba(67,124,144,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  ul li a:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(67,124,144,0.18);
  }
  .name-initial {
    width: 48px;
    height: 48px;
    min-width: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #437c90, #255957);
    color: #f7c548;
    font-size: 1.5em;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .post-info {
    min-width: 0;
    overflow: hidden;
  }
  .title {
    margin: 0 0 0.2em;
    color: #255957;
    font-size: 1.15em;
    font-weight: 700;
  }
  .desc {
    margin: 0 0 0.4em;
    color: #437c90;
    font-size: 0.82em;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .date {
    margin: 0;
    color: #a98743;
    font-size: 0.78em;
  }
  @media (max-width: 600px) {
    ul { grid-template-columns: 1fr; }
    .page-hero { padding: 2.5em 1em; }
    .page-hero h1 { font-size: 1.8em; }
    #search-input { font-size: 0.95em; }
  }
</style>
