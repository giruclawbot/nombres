---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={`Lista de Nombres · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <div class="page-hero">
      <h1>📚 Lista de Nombres</h1>
      <p>{posts.length} nombres con historia, origen y variantes</p>
    </div>
    <main>
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`${base}/blog/${post.id}/`}>
              <div class="name-initial">{post.data.title.charAt(0)}</div>
              <div class="post-info">
                <h4 class="title">{post.data.title}</h4>
                <p class="desc">{post.data.description}</p>
                <p class="date">
                  <FormattedDate date={post.data.pubDate} />
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-hero {
    background: linear-gradient(135deg, #255957, #437c90);
    padding: 3em 2em;
    text-align: center;
    color: #eeebd3;
  }
  .page-hero h1 {
    color: #f7c548;
    margin: 0 0 0.3em;
    font-size: 2.4em;
  }
  .page-hero p {
    margin: 0;
    opacity: 0.85;
    font-size: 1em;
  }
  main {
    width: 960px;
    max-width: calc(100% - 2em);
    margin: 0 auto;
    padding: 3em 1em;
  }
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5em;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  ul li a {
    display: flex;
    align-items: flex-start;
    gap: 1em;
    background: #fff;
    border-radius: 14px;
    padding: 1.4em;
    text-decoration: none;
    border: 1px solid rgba(67,124,144,0.15);
    box-shadow: 0 2px 10px rgba(67,124,144,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
    height: 100%;
    box-sizing: border-box;
  }
  ul li a:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(67,124,144,0.18);
  }
  .name-initial {
    width: 48px;
    height: 48px;
    min-width: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #437c90, #255957);
    color: #f7c548;
    font-size: 1.5em;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .title {
    margin: 0 0 0.2em;
    color: #255957;
    font-size: 1.15em;
    font-weight: 700;
  }
  .desc {
    margin: 0 0 0.4em;
    color: #437c90;
    font-size: 0.82em;
    line-height: 1.4;
  }
  .date {
    margin: 0;
    color: #a98743;
    font-size: 0.78em;
  }
  @media (max-width: 600px) {
    ul { grid-template-columns: 1fr; }
    .page-hero h1 { font-size: 1.8em; }
  }
</style>
