---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recentPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <section class="hero">
      <div class="hero-content">
        <div class="hero-icon">✨</div>
        <h1>Descubre el poder de los nombres</h1>
        <p>Explora el origen, significado e historia de los nombres más populares en español. Cada nombre tiene una historia única que contar.</p>
        <a href={`${base}/blog`} class="cta-btn">Ver todos los nombres →</a>
      </div>
    </section>

    <section class="stats">
      <div class="stat">
        <span class="stat-number">{posts.length}</span>
        <span class="stat-label">nombres</span>
      </div>
      <div class="stat">
        <span class="stat-number">🌎</span>
        <span class="stat-label">variantes internacionales</span>
      </div>
      <div class="stat">
        <span class="stat-number">📖</span>
        <span class="stat-label">historia y origen</span>
      </div>
    </section>

    <main>
      <h2 class="section-title">Últimos nombres agregados</h2>
      <div class="names-grid">
        {recentPosts.map((post) => (
          <a href={`${base}/blog/${post.id}/`} class="name-card">
            <div class="name-initial">{post.data.title.charAt(0)}</div>
            <div class="name-info">
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="view-all">
        <a href={`${base}/blog`} class="view-all-link">Ver todos los nombres →</a>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .hero {
    background: linear-gradient(135deg, #255957 0%, #437c90 60%, #a98743 100%);
    padding: 5em 2em;
    text-align: center;
    color: #eeebd3;
  }
  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }
  .hero-icon {
    font-size: 3.5em;
    margin-bottom: 0.3em;
  }
  .hero h1 {
    color: #f7c548;
    font-size: 2.6em;
    margin-bottom: 0.5em;
    line-height: 1.2;
  }
  .hero p {
    font-size: 1.15em;
    opacity: 0.9;
    margin-bottom: 2em;
    line-height: 1.7;
  }
  .cta-btn {
    display: inline-block;
    background: #f7c548;
    color: #255957;
    font-weight: 700;
    padding: 0.75em 2em;
    border-radius: 50px;
    text-decoration: none;
    font-size: 1em;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 15px rgba(247, 197, 72, 0.4);
  }
  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(247, 197, 72, 0.5);
    color: #255957;
  }

  .stats {
    background: #255957;
    display: flex;
    justify-content: center;
    gap: 4em;
    padding: 1.8em 2em;
    flex-wrap: wrap;
  }
  .stat {
    text-align: center;
    color: #eeebd3;
  }
  .stat-number {
    display: block;
    font-size: 2em;
    font-weight: 700;
    color: #f7c548;
  }
  .stat-label {
    font-size: 0.85em;
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 3em 1.5em;
  }
  .section-title {
    font-size: 1.8em;
    color: #255957;
    margin-bottom: 1.2em;
    border-left: 4px solid #f7c548;
    padding-left: 0.6em;
  }

  .names-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5em;
  }
  .name-card {
    display: flex;
    align-items: flex-start;
    gap: 1em;
    background: #fff;
    border-radius: 12px;
    padding: 1.4em;
    text-decoration: none;
    border: 1px solid rgba(67, 124, 144, 0.15);
    box-shadow: 0 2px 10px rgba(67, 124, 144, 0.08);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .name-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(67, 124, 144, 0.18);
  }
  .name-initial {
    width: 48px;
    height: 48px;
    min-width: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #437c90, #255957);
    color: #f7c548;
    font-size: 1.5em;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .name-info h3 {
    margin: 0 0 0.2em;
    color: #255957;
    font-size: 1.15em;
  }
  .name-info p {
    margin: 0;
    color: #437c90;
    font-size: 0.85em;
    line-height: 1.4;
  }

  .view-all {
    text-align: center;
    margin-top: 2.5em;
  }
  .view-all-link {
    color: #437c90;
    font-weight: 700;
    text-decoration: none;
    font-size: 1em;
    border-bottom: 2px solid #f7c548;
    padding-bottom: 2px;
    transition: color 0.2s;
  }
  .view-all-link:hover {
    color: #255957;
  }

  @media (max-width: 600px) {
    .hero h1 { font-size: 1.9em; }
    .stats { gap: 2em; }
    .names-grid { grid-template-columns: 1fr; }
  }
</style>
