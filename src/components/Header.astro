---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header>
  <nav>
    <h2><a href={`${base}/`}>{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href={`${base}/`}>Inicio</HeaderLink>
      <HeaderLink href={`${base}/blog`}>Lista de Nombres</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1.5em;
    background: linear-gradient(135deg, #255957, #437c90);
    box-shadow: 0 2px 12px rgba(37, 89, 87, 0.3);
  }
  h2 {
    margin: 0;
    font-size: 1.1em;
  }
  h2 a,
  h2 a.active {
    text-decoration: none;
    color: #f7c548;
    font-weight: 700;
    letter-spacing: 0.03em;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 960px;
    margin: 0 auto;
  }
  nav a {
    padding: 1.1em 0.75em;
    color: #eeebd3;
    border-bottom: 3px solid transparent;
    text-decoration: none;
    font-size: 0.95em;
    transition: color 0.2s, border-color 0.2s;
  }
  nav a:hover {
    color: #f7c548;
  }
  nav a.active {
    color: #f7c548;
    border-bottom-color: #f7c548;
  }
  @media (max-width: 600px) {
    header {
      padding: 0 1em;
    }
    nav {
      flex-wrap: wrap;
      gap: 0;
    }
    h2 {
      width: 100%;
      padding: 0.8em 0 0.4em;
      font-size: 1em;
    }
    .internal-links {
      display: flex;
      width: 100%;
      border-top: 1px solid rgba(238, 235, 211, 0.15);
    }
    nav a {
      padding: 0.7em 0.5em;
      font-size: 0.88em;
    }
  }
</style>
